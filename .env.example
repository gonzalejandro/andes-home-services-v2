# Jobber OAuth (Week 2 — contact form)
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_REFRESH_TOKEN=
JOBBER_GRAPHQL_VERSION=2026-05-12

# Cloudflare Turnstile (contact form CAPTCHA — dashboard: Turnstile → Add site)
# PUBLIC_ prefix exposes the site key to the browser; the secret stays server-only.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Maps reviews scraper (npm run scrape:reviews)
# GOOGLE_MAPS_REVIEWS_URL=https://www.google.com/maps/place/...
# SCRAPE_REVIEW_PAGES=max
# REVIEWS_MAX_AGE_DAYS=7

# Vercel Blob — stores refreshed reviews in production (Vercel dashboard → Storage → Blob)
# BLOB_READ_WRITE_TOKEN=
