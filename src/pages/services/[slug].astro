---
import { Image } from 'astro:assets';
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { services } from '../../data/services';
import { site } from '../../config/site';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<PageLayout
  title={`${service.title} | ${site.name}`}
  description={service.description}
  heroTitle={service.title}
  heroSubtitle={service.shortDescription}
  heroImage={service.image}
>
  <section class="section-padding">
    <div class="container-page grid items-start gap-10 lg:grid-cols-2">
      <div class="space-y-4 text-lg text-brand-900/75">
        <p>{service.description}</p>
        <ul class="list-disc space-y-2 pl-5">
          {service.highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </div>
      <Image
        src={service.image}
        alt={service.imageAlt}
        class="rounded-2xl shadow-lg"
        loading="lazy"
      />
    </div>
  </section>

  <CTABanner
    title={`Get a free ${service.title.toLowerCase()} estimate`}
    description="Share your project details and we will get back to you quickly."
    href="/contact"
  />
</PageLayout>
