---
import PageLayout from '../layouts/PageLayout.astro';
import ContactInfo from '../components/ContactInfo.astro';
import ContactForm from '../components/ContactForm';
import { site } from '../config/site';
---

<PageLayout
  title={`Contact | ${site.name}`}
  description={`Request a free stump grinding estimate from ${site.name}. Call ${site.phone} or send us a message.`}
  heroTitle="Get In Touch"
  heroSubtitle="Request your free stump-grinding quote. Fully insured."
>
  <section class="section-padding">
    <div class="container-page grid gap-8 lg:grid-cols-[1fr_1.2fr]">
      <ContactInfo />
      <div>
        <ContactForm client:load />
        <p class="mt-4 text-center text-sm text-brand-900/60">
          Outside Macomb, Oakland, or Wayne County? We can still help — a travel fee may apply.
        </p>
      </div>
    </div>
  </section>
</PageLayout>
