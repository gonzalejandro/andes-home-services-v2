---
import { Image } from 'astro:assets';
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTABanner from '../components/CTABanner.astro';
import { galleryImages } from '../data/gallery';
import { getInstagramFeedWithRefresh } from '../lib/instagram-cache';
import { getVideos } from '../lib/instagram';
import { site } from '../config/site';

const instagramVideos = getVideos(await getInstagramFeedWithRefresh());
---

<PageLayout
  title={`Gallery | ${site.name}`}
  description="Photos of professional stump grinding equipment and projects across Metro Detroit."
  heroTitle="Project Gallery"
  heroSubtitle="Professional equipment and real stump grinding work."
>
  <section class="section-padding">
    <div class="container-page">
      <SectionHeading
        title="Our Work"
        subtitle="Add before/after photos here as you collect them from the field."
      />
      <div class="grid gap-6 sm:grid-cols-2">
        {
          galleryImages.map((image) => (
            <figure class="card overflow-hidden p-0">
              <Image
                src={image.src}
                alt={image.alt}
                class="h-64 w-full object-cover"
                loading="lazy"
              />
              <figcaption class="p-4 text-sm font-medium text-brand-900/75">
                {image.caption}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  {
    instagramVideos.length > 0 && (
      <section class="section-padding pt-0">
        <div class="container-page">
          <SectionHeading
            title="From Instagram"
            subtitle="Recent stump grinding videos from our Instagram."
          />
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {instagramVideos.map((video) => (
              <figure class="card overflow-hidden p-0">
                <video
                  src={video.mediaUrl}
                  poster={video.thumbnailUrl}
                  class="aspect-[9/16] w-full bg-black object-cover"
                  controls
                  playsinline
                  preload="none"
                />
                <figcaption class="flex items-center justify-between gap-3 p-4 text-sm">
                  {video.caption && (
                    <span class="line-clamp-2 font-medium text-brand-900/75">
                      {video.caption}
                    </span>
                  )}
                  <a
                    href={video.permalink}
                    target="_blank"
                    rel="noopener"
                    class="shrink-0 font-semibold text-brand-700 hover:text-brand-900"
                  >
                    View on Instagram
                  </a>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CTABanner
    title="Want results like this on your property?"
    description="Send us a few details and we will provide a free estimate."
    href="/contact"
  />
</PageLayout>
