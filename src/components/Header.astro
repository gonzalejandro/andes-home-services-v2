---
import { Image } from 'astro:assets';
import logo from '../assets/andes-stump-grinding.png';
import { site, navLinks } from '../config/site';
import SocialLinks from './SocialLinks.astro';

const currentPath = Astro.url.pathname;
---

<header class="bg-gradient-to-br from-brand-800 to-brand-700 text-white shadow-md">
  <div class="container-page py-4 md:py-6">
    <div class="relative flex items-center justify-center">
      <a href="/" class="flex items-center gap-3 md:gap-4">
        <Image
          src={logo}
          alt={site.name}
          class="h-20 w-auto brightness-0 invert md:h-28"
        />
        <div class="hidden sm:block">
          <p class="text-xl font-bold tracking-wide md:text-3xl">{site.name}</p>
          <p class="text-xs uppercase tracking-widest text-white/80 md:text-sm">
            Professional Stump Grinding Services
          </p>
        </div>
      </a>

      <button
        id="mobile-menu-button"
        type="button"
        class="absolute right-0 inline-flex items-center justify-center rounded-lg border border-white/20 p-2 text-white md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle navigation menu"
      >
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <nav class="mt-4 hidden items-center gap-4 border-t border-white/20 pt-4 md:flex" aria-label="Main navigation">
      <ul class="flex flex-1 flex-wrap items-center justify-center gap-1 lg:gap-2">
        {
          navLinks.map((link) => {
            const isActive =
              link.href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(link.href);
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'rounded-full px-3 py-2 text-sm font-medium transition lg:px-4',
                    isActive
                      ? 'bg-white/15 text-white'
                      : 'text-white/85 hover:bg-white/10 hover:text-white',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <SocialLinks class="shrink-0" />
    </nav>

    <nav
      id="mobile-menu"
      class="mt-4 hidden border-t border-white/20 pt-4 md:hidden"
      aria-label="Mobile navigation"
    >
      <SocialLinks class="mb-4 justify-center" />
      <ul class="grid gap-1">
        {
          navLinks.map((link) => {
            const isActive =
              link.href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(link.href);
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'block rounded-lg px-3 py-2 text-sm font-medium',
                    isActive ? 'bg-white/15' : 'hover:bg-white/10',
                  ]}
                >
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    button.setAttribute('aria-expanded', String(isOpen));
  });
</script>
