---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="card">
  <div class="text-3xl" aria-hidden="true">{icon}</div>
  <h3 class="mt-3 text-lg font-bold text-brand-800">{title}</h3>
  <p class="mt-2 text-brand-900/75">{description}</p>
</div>
