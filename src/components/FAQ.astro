---
import { faqSections } from '../data/faq';
---

<div class="mx-auto max-w-3xl space-y-8">
  {
    faqSections.map((section, sectionIndex) => (
      <div>
        <h2 class="mb-4 text-xl font-bold text-brand-800">{section.title}</h2>
        <div class="divide-y divide-brand-200 rounded-2xl border border-brand-200 bg-white">
          {section.items.map((item, itemIndex) => (
            <details class="group p-5" open={sectionIndex === 0 && itemIndex === 0}>
              <summary class="cursor-pointer list-none font-semibold text-brand-800 marker:content-none">
                <span class="flex items-start justify-between gap-4">
                  <span>{item.question}</span>
                  <span class="text-accent transition group-open:rotate-180" aria-hidden="true">▼</span>
                </span>
              </summary>
              <p class="mt-3 text-brand-900/75">{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    ))
  }
</div>
