---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import backgroundDefault from '../assets/background.jpg';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata;
}

const {
  title,
  subtitle,
  image = backgroundDefault,
} = Astro.props;

const optimizedBg = await getImage({ src: image, format: 'webp' });
---

<section
  class="relative bg-brand-800 bg-cover bg-center bg-fixed text-white"
  style={`background-image: linear-gradient(rgba(5, 51, 34, 0.35), rgba(6, 64, 43, 0.25)), url('${optimizedBg.src}')`}
>
  <div class="container-page section-padding text-center">
    <h1 class="text-4xl font-bold tracking-tight text-shadow md:text-5xl lg:text-6xl">
      {title}
    </h1>
    {subtitle && (
      <p class="mx-auto mt-4 max-w-2xl text-lg text-white/90 md:text-xl">{subtitle}</p>
    )}
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href="/contact" class="btn-primary">Get a Free Estimate</a>
      <a
        href="/services"
        class="btn-secondary border-white text-white hover:bg-white hover:text-brand-800"
      >
        About Our Services
      </a>
    </div>
  </div>
</section>

<style>
  .text-shadow {
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }
</style>
